{
  "openapi": "3.0.1",
  "info": {
    "title": "MCCY EU",
    "version": "1.0MCCYEU"
  },
  "paths": {
    "/payments/cross-border/v1/payments": {
      "post": {
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/InitiatePaymentRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/InitiatePaymentResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "409": {
            "description": "Conflict"
          },
          "501": {
            "description": "Not Implemented"
          }
        }
      }
    },
    "/payments/cross-border/v1/payments/accept": {
      "post": {
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ExecutePaymentRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "description": "Accepted"
          },
          "400": {
            "description": "Bad Request"
          },
          "501": {
            "description": "Not Implemented"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Agent": {
        "required": [
          "bicfi",
          "name",
          "postalAddress"
        ],
        "type": "object",
        "properties": {
          "name": {
            "maxLength": 140,
            "minLength": 1,
            "type": "string",
            "description": "The legal name of this agent.",
            "example": "Lime Banking"
          },
          "postalAddress": {
            "$ref": "#/components/schemas/BasicAddress"
          },
          "bicfi": {
            "maxLength": 11,
            "minLength": 8,
            "pattern": "[A-Z0-9]{4,4}[A-Z]{2,2}[A-Z0-9]{2,2}([A-Z0-9]{3,3}){0,1}",
            "type": "string",
            "description": "This financial institution's Business Identifier Code (BIC).",
            "example": "CLRBNLA1AB1"
          },
          "lei": {
            "maxLength": 20,
            "minLength": 20,
            "pattern": "[A-Z0-9]{18,18}[0-9]{2,2}",
            "type": "string",
            "description": "The Legal Entity Identifier (LEI) of this party.",
            "nullable": true,
            "example": "1234ABCLILUYNFL66E11"
          }
        },
        "additionalProperties": false,
        "description": "Details of a financial institution involved with this payment."
      },
      "BasicAddress": {
        "required": [
          "country",
          "townName"
        ],
        "type": "object",
        "properties": {
          "townName": {
            "maxLength": 35,
            "minLength": 1,
            "pattern": "[0-9a-zA-Z\\/\\\\-\\\\?:\\\\(\\\\)\\\\.,'\\\\+!#$%&\\\\*=^_`\\\\{\\\\|\\\\}~\\\";<>@\\\\[\\\\\\\\\\\\]](|[0-9a-zA-Z\\/\\\\-\\\\?:\\\\(\\\\)\\\\.,'\\\\+!#$%&\\\\*=^_`\\\\{\\\\|\\\\}~\\\";<>@\\\\[\\\\\\\\\\\\]]|[0-9a-zA-Z\\/\\\\-\\\\?:\\\\(\\\\)\\\\.,'\\\\+ !#$%&\\\\*=^_`\\\\{\\\\|\\\\}~\\\";<>@\\\\[\\\\\\\\\\\\]]{1,33}[0-9a-zA-Z\\/\\\\-\\\\?:\\\\(\\\\)\\\\.,'\\\\+!#$%&\\\\*=^_`\\\\{\\\\|\\\\}~\\\";<>@\\\\[\\\\\\\\\\\\]])",
            "type": "string",
            "description": "Name of a built-up area, with defined boundaries, and a local government.",
            "example": "Brussels"
          },
          "country": {
            "maxLength": 2,
            "minLength": 2,
            "pattern": "[A-Z]{2,2}",
            "type": "string",
            "description": "The country this address is in, given as an ISO 3166 2-digit country code.",
            "example": "BE"
          }
        },
        "additionalProperties": false,
        "description": "The postal address of this agent."
      },
      "CreditorAgent": {
        "required": [
          "bicfi"
        ],
        "type": "object",
        "properties": {
          "bicfi": {
            "maxLength": 11,
            "minLength": 8,
            "pattern": "[A-Z0-9]{4,4}[A-Z]{2,2}[A-Z0-9]{2,2}([A-Z0-9]{3,3}){0,1}",
            "type": "string",
            "description": "This financial institution's Business Identifier Code (BIC).",
            "example": "ABCDFR0B123"
          }
        },
        "additionalProperties": false,
        "description": "Information about the creditor agent."
      },
      "CurrencyAmount": {
        "required": [
          "amount",
          "currency"
        ],
        "type": "object",
        "properties": {
          "amount": {
            "type": "number",
            "description": "Indicates the amount of a given currency to be used.",
            "format": "double",
            "example": 30572.55
          },
          "currency": {
            "maxLength": 3,
            "minLength": 3,
            "type": "string",
            "description": "The currency, given as a three letter ISO 4217 currency code.",
            "example": "GBP"
          }
        },
        "additionalProperties": false,
        "description": "A number of monetary units specified in an active or a historic currency where the unit of currency is explicit and compliant with ISO 4217."
      },
      "DateAndPlaceOfBirth": {
        "required": [
          "birthDate",
          "cityOfBirth",
          "countryOfBirth"
        ],
        "type": "object",
        "properties": {
          "birthDate": {
            "maxLength": 10,
            "minLength": 10,
            "pattern": "\\\\d{4}\\\\-(0[1-9]|1[012])\\\\-(0[1-9]|[12][0-9]|3[01])",
            "type": "string",
            "description": "This party's date of birth, formatted yyyy-MM-dd.",
            "example": "1981-11-22"
          },
          "cityOfBirth": {
            "maxLength": 35,
            "minLength": 1,
            "pattern": "[0-9a-zA-Z\\/\\\\-\\\\?:\\\\(\\\\)\\\\.,'\\\\+!#$%&\\\\*=^_`\\\\{\\\\|\\\\}~\\\";<>@\\\\[\\\\\\\\\\\\]](|[0-9a-zA-Z\\/\\\\-\\\\?:\\\\(\\\\)\\\\.,'\\\\+!#$%&\\\\*=^_`\\\\{\\\\|\\\\}~\\\";<>@\\\\[\\\\\\\\\\\\]]|[0-9a-zA-Z\\/\\\\-\\\\?:\\\\(\\\\)\\\\.,'\\\\+ !#$%&\\\\*=^_`\\\\{\\\\|\\\\}~\\\";<>@\\\\[\\\\\\\\\\\\]]{1,33}[0-9a-zA-Z\\/\\\\-\\\\?:\\\\(\\\\)\\\\.,'\\\\+!#$%&\\\\*=^_`\\\\{\\\\|\\\\}~\\\";<>@\\\\[\\\\\\\\\\\\]])",
            "type": "string",
            "description": "This party's city of birth.",
            "example": "Leon"
          },
          "countryOfBirth": {
            "maxLength": 2,
            "minLength": 2,
            "pattern": "[A-Z]{2,2}",
            "type": "string",
            "description": "This party's country of birth, given as a two letter ISO 3166 country code.",
            "example": "FR"
          },
          "provinceOfBirth": {
            "maxLength": 35,
            "minLength": 1,
            "pattern": "[0-9a-zA-Z\\/\\\\-\\\\?:\\\\(\\\\)\\\\.,'\\\\+!#$%&\\\\*=^_`\\\\{\\\\|\\\\}~\\\";<>@\\\\[\\\\\\\\\\\\]](|[0-9a-zA-Z\\/\\\\-\\\\?:\\\\(\\\\)\\\\.,'\\\\+!#$%&\\\\*=^_`\\\\{\\\\|\\\\}~\\\";<>@\\\\[\\\\\\\\\\\\]]|[0-9a-zA-Z\\/\\\\-\\\\?:\\\\(\\\\)\\\\.,'\\\\+ !#$%&\\\\*=^_`\\\\{\\\\|\\\\}~\\\";<>@\\\\[\\\\\\\\\\\\]]{1,33}[0-9a-zA-Z\\/\\\\-\\\\?:\\\\(\\\\)\\\\.,'\\\\+!#$%&\\\\*=^_`\\\\{\\\\|\\\\}~\\\";<>@\\\\[\\\\\\\\\\\\]])",
            "type": "string",
            "description": "This party's province of birth.",
            "nullable": true,
            "example": "Landes"
          }
        },
        "additionalProperties": false,
        "description": "Party's date and place of birth."
      },
      "ExecutePaymentRequest": {
        "required": [
          "uetr"
        ],
        "type": "object",
        "properties": {
          "uetr": {
            "type": "string",
            "description": "A universally unique identifier to provide an end-to-end reference for this payment transaction.",
            "format": "uuid",
            "example": "013f6468-dd30-54b6-9003-11cf68b1b989"
          }
        },
        "additionalProperties": false
      },
      "IbanAccount": {
        "required": [
          "currency",
          "iban"
        ],
        "type": "object",
        "properties": {
          "currency": {
            "maxLength": 3,
            "minLength": 3,
            "pattern": "[A-Z]{3}",
            "type": "string",
            "description": "The currency of this account, given as a three letter ISO-4217 currency code.",
            "example": "EUR"
          },
          "iban": {
            "maxLength": 34,
            "minLength": 5,
            "pattern": "[A-Z]{2,2}[0-9]{2,2}[a-zA-Z0-9]{1,30}",
            "type": "string",
            "description": "This account's International Bank Account Number (IBAN).",
            "example": "NL11ABCD1234123400"
          }
        },
        "additionalProperties": false,
        "description": "Information about the creditor or debtor account in a given transaction."
      },
      "IbanOrOtherAccount": {
        "required": [
          "currency"
        ],
        "type": "object",
        "properties": {
          "currency": {
            "maxLength": 3,
            "minLength": 3,
            "pattern": "[A-Z]{3}",
            "type": "string",
            "description": "The currency of this account, given as a three letter ISO 4217 currency code.",
            "example": "GBP"
          },
          "iban": {
            "maxLength": 34,
            "minLength": 5,
            "pattern": "[A-Z]{2,2}[0-9]{2,2}[a-zA-Z0-9]{1,30}",
            "type": "string",
            "description": "This account's International Bank Account Number (IBAN).\r\n            Either the 'nonIban' or 'iban' field should be provided, not both.",
            "nullable": true,
            "example": "NL11ABCD1234123400"
          },
          "nonIban": {
            "type": "string",
            "description": "This account's non-IBAN account identifier.\r\n            Either the 'nonIban' or 'iban' field should be provided, not both.",
            "nullable": true,
            "example": "ABCD1234123400"
          },
          "accountIdentifierString": {
            "type": "string",
            "nullable": true,
            "readOnly": true
          }
        },
        "additionalProperties": false,
        "description": "Information about the creditor or debtor's account in a given transaction, which may be an IBAN or other account identifier."
      },
      "InitiatePaymentRequest": {
        "required": [
          "creditor",
          "creditorAccount",
          "creditorAgent",
          "debtor",
          "debtorAccount",
          "endToEndIdentification",
          "instructionIdentification",
          "uetr"
        ],
        "type": "object",
        "properties": {
          "uetr": {
            "type": "string",
            "description": "A universally unique identifier to provide an end-to-end reference for this payment transaction.",
            "format": "uuid",
            "example": "013f6468-dd30-54b6-9003-11cf68b1b989"
          },
          "endToEndIdentification": {
            "maxLength": 35,
            "minLength": 1,
            "pattern": "[0-9a-zA-Z/\\-?:().,'\\+](|[0-9a-zA-Z/\\-?:().,'\\+]|[0-9a-zA-Z/\\-?:().,'\\+ ]{1,33}[0-9a-zA-Z/\\-?:().,'\\+])",
            "type": "string",
            "description": "Unique identification, as assigned by the initiating party, to unambiguously identify the transaction. This identification is passed on, unchanged, throughout the entire end-to-end chain.",
            "example": "bXuC9HimDlI0X3Ygmk525Cxb8dYzUddpj4T"
          },
          "instructionIdentification": {
            "maxLength": 35,
            "minLength": 1,
            "pattern": "[0-9a-zA-Z/\\-?:().,'\\+](|[0-9a-zA-Z/\\-?:().,'\\+]|[0-9a-zA-Z/\\-?:().,'\\+ ]{1,33}[0-9a-zA-Z/\\-?:().,'\\+])",
            "type": "string",
            "description": "Unique identification, as assigned by an instructing party for an instructed party, to unambiguously identify the instruction.",
            "example": "my-instruction-ident 111ABC-321"
          },
          "debtor": {
            "$ref": "#/components/schemas/PartyInformation"
          },
          "debtorAccount": {
            "$ref": "#/components/schemas/IbanAccount"
          },
          "creditor": {
            "$ref": "#/components/schemas/PartyInformation"
          },
          "creditorAccount": {
            "$ref": "#/components/schemas/IbanOrOtherAccount"
          },
          "creditorAgent": {
            "$ref": "#/components/schemas/CreditorAgent"
          },
          "interbankSettlementAmount": {
            "$ref": "#/components/schemas/CurrencyAmount"
          },
          "instructedAmount": {
            "$ref": "#/components/schemas/CurrencyAmount"
          },
          "ultimateCreditor": {
            "$ref": "#/components/schemas/PartyInformation"
          },
          "ultimateDebtor": {
            "$ref": "#/components/schemas/PartyInformation"
          },
          "purpose": {
            "type": "string",
            "description": "The underlying reason for the payment transaction, as published in an external purpose code list (ExternalPurpose1Code).",
            "nullable": true,
            "example": "COST"
          },
          "remittanceInformationUnstructured": {
            "maxLength": 140,
            "minLength": 1,
            "pattern": "[0-9a-zA-Z/\\-?:().,'\\+!#$%&\\*=^_`\\{\\|\\}~\";<>@\\[\\]\\\\](|[0-9a-zA-Z/\\-?:().,'\\+!#$%&\\*=^_`\\{\\|\\}~\";<>@\\[\\]\\\\]|[0-9a-zA-Z/\\-?:().,'\\+ !#$%&\\*=^_`\\{\\|\\}~\";<>@\\[\\]\\\\]{1,138}[0-9a-zA-Z/\\-?:().,'\\+!#$%&\\*=^_`\\{\\|\\}~\";<>@\\[\\]\\\\])",
            "type": "string",
            "description": "Information supplied to enable the matching of an entry with the items that the transfer is intended to settle,\r\nfor example, commercial invoices in an accounts' receivable system in an unstructured form.",
            "nullable": true,
            "example": "My example unstructured remittance information 33-UK-ABC"
          },
          "previousInstructingAgents": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/PreviousInstructingAgent"
            },
            "description": "An array of agents who were previously involved with this payment.",
            "nullable": true
          }
        },
        "additionalProperties": false,
        "description": "Institution Payment Request (pacs.008)"
      },
      "InitiatePaymentResponse": {
        "type": "object",
        "properties": {
          "uetr": {
            "type": "string",
            "format": "uuid",
            "description": "The universally unique identifier you provided when requesting this payment transaction.",
            "example": "013f6468-dd30-54b6-9003-11cf68b1b989"
          },
          "exchangeRate": {
            "type": "number",
            "format": "double",
            "example": 0.87,
            "description": "The exchange rate of this payment for the requested currency pair (Origin:Target)."
          },
          "instructedCurrency": {
            "type": "string",
            "nullable": true,
            "description": "The currency this payment will use from your account, given as a three letter ISO 4217 currency code.",
            "example": "EUR"
          },
          "instructedAmount": {
            "type": "number",
            "format": "double",
            "description": "The amount of the origin currency that will be paid from your account for this transaction, including fees.",
            "example": 30572.55
          },
          "interbankSettlementCurrency": {
            "type": "string",
            "nullable": true,
            "description": "The target currency that the recipient will receive, given as a three letter ISO 4217 currency code.",
            "example": "GBP"
          },
          "interbankSettlementAmount": {
            "type": "number",
            "format": "double",
            "description": "The amount of the target currency that the recipient will receive after fees.",
            "example": 26598.11
          },
          "paymentValueDate": {
            "type": "string",
            "format": "date-time",
            "example": "2025-01-10T06:04:00",
            "description": "The date-time this payment request was valued at."
          },
          "expiryDateTime": {
            "type": "string",
            "format": "date-time",
            "example": "2025-01-10T06:05:30",
            "description": "The date-time this open payment request will expire if it is not accepted first."
          }
        },
        "additionalProperties": false
      },
      "OrganisationIdentification": {
        "type": "object",
        "properties": {
          "anyBic": {
            "maxLength": 11,
            "minLength": 8,
            "pattern": "[A-Z0-9]{4,4}[A-Z]{2,2}[A-Z0-9]{2,2}([A-Z0-9]{3,3}){0,1}",
            "type": "string",
            "description": "The Business Identifier Code (BIC) assigned by SWIFT to this non-financial institution.",
            "nullable": true,
            "example": "CLRBGB10321"
          },
          "lei": {
            "maxLength": 20,
            "minLength": 20,
            "pattern": "[A-Z0-9]{18,18}[0-9]{2,2}",
            "type": "string",
            "description": "The Legal Entity Identifier (LEI) of this party.",
            "nullable": true,
            "example": "D7R3AROG1XRMZ3LXI712"
          },
          "other": {
            "minItems": 1,
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Other"
            },
            "description": "An array of other identifiers for this organisation.",
            "nullable": true
          }
        },
        "additionalProperties": false,
        "description": "Information about the organisation."
      },
      "Other": {
        "required": [
          "id",
          "issuer",
          "schemeName"
        ],
        "type": "object",
        "properties": {
          "id": {
            "maxLength": 35,
            "minLength": 1,
            "pattern": "[0-9a-zA-Z\\/\\\\-\\\\?:\\\\(\\\\)\\\\.,'\\\\+](|[0-9a-zA-Z\\/\\\\-\\\\?:\\\\(\\\\)\\\\.,'\\\\+]|[0-9a-zA-Z\\/\\\\-\\\\?:\\\\(\\\\)\\\\.,'\\\\+ ]{1,33}[0-9a-zA-Z\\/\\\\-\\\\?:\\\\(\\\\)\\\\.,'\\\\+])",
            "type": "string",
            "description": "Unambiguous Identification for the given scheme.",
            "example": "12344321"
          },
          "schemeName": {
            "$ref": "#/components/schemas/SchemeName"
          },
          "issuer": {
            "maxLength": 35,
            "minLength": 1,
            "pattern": "[0-9a-zA-Z\\/\\\\-\\\\?:\\\\(\\\\)\\\\.,'\\\\+](|[0-9a-zA-Z\\/\\\\-\\\\?:\\\\(\\\\)\\\\.,'\\\\+]|[0-9a-zA-Z\\/\\\\-\\\\?:\\\\(\\\\)\\\\.,'\\\\+ ]{1,33}[0-9a-zA-Z\\/\\\\-\\\\?:\\\\(\\\\)\\\\.,'\\\\+])",
            "type": "string",
            "description": "The name of the entity that assigns the identification.",
            "example": "Companies House"
          }
        },
        "additionalProperties": false,
        "description": "Unambiguous identification using the given scheme."
      },
      "PartyInformation": {
        "required": [
          "name",
          "postalAddress"
        ],
        "type": "object",
        "properties": {
          "name": {
            "maxLength": 140,
            "minLength": 1,
            "pattern": "[0-9a-zA-Z\\/\\\\-\\\\?:\\\\(\\\\)\\\\.,'\\\\+!#$%&\\\\*=^_`\\\\{\\\\|\\\\}~\\\";<>@\\\\[\\\\\\\\\\\\]](|[0-9a-zA-Z\\/\\\\-\\\\?:\\\\(\\\\)\\\\.,'\\\\+!#$%&\\\\*=^_`\\\\{\\\\|\\\\}~\\\";<>@\\\\[\\\\\\\\\\\\]]|[0-9a-zA-Z\\/\\\\-\\\\?:\\\\(\\\\)\\\\.,'\\\\+ !#$%&\\\\*=^_`\\\\{\\\\|\\\\}~\\\";<>@\\\\[\\\\\\\\\\\\]]{1,138}[0-9a-zA-Z\\/\\\\-\\\\?:\\\\(\\\\)\\\\.,'\\\\+!#$%&\\\\*=^_`\\\\{\\\\|\\\\}~\\\";<>@\\\\[\\\\\\\\\\\\]])",
            "type": "string",
            "description": "The legal name of this party.",
            "example": "Martina Hicks"
          },
          "postalAddress": {
            "$ref": "#/components/schemas/PostalAddress"
          },
          "countryOfResidence": {
            "maxLength": 2,
            "minLength": 2,
            "pattern": "[A-Z]{2,2}",
            "type": "string",
            "description": "The party's country of residence, given as a two letter ISO 3166 country code.",
            "nullable": true,
            "example": "NL"
          },
          "organisationIdentification": {
            "$ref": "#/components/schemas/OrganisationIdentification"
          },
          "privateIdentification": {
            "$ref": "#/components/schemas/PrivateIdentification"
          }
        },
        "additionalProperties": false,
        "description": "The name and, optionally, the legal entity identifier of the account. Details of the party. You should provide 'organisationIdentification' or 'privateIdentification' for the party, but not both."
      },
      "PostalAddress": {
        "required": [
          "country",
          "townName"
        ],
        "type": "object",
        "properties": {
          "townName": {
            "maxLength": 35,
            "minLength": 1,
            "pattern": "[0-9a-zA-Z\\/\\\\-\\\\?:\\\\(\\\\)\\\\.,'\\\\+!#$%&\\\\*=^_`\\\\{\\\\|\\\\}~\\\";<>@\\\\[\\\\\\\\\\\\]](|[0-9a-zA-Z\\/\\\\-\\\\?:\\\\(\\\\)\\\\.,'\\\\+!#$%&\\\\*=^_`\\\\{\\\\|\\\\}~\\\";<>@\\\\[\\\\\\\\\\\\]]|[0-9a-zA-Z\\/\\\\-\\\\?:\\\\(\\\\)\\\\.,'\\\\+ !#$%&\\\\*=^_`\\\\{\\\\|\\\\}~\\\";<>@\\\\[\\\\\\\\\\\\]]{1,33}[0-9a-zA-Z\\/\\\\-\\\\?:\\\\(\\\\)\\\\.,'\\\\+!#$%&\\\\*=^_`\\\\{\\\\|\\\\}~\\\";<>@\\\\[\\\\\\\\\\\\]])",
            "type": "string",
            "description": "Name of a built-up area, with defined boundaries, and a local government.",
            "example": "Amsterdam"
          },
          "country": {
            "maxLength": 2,
            "minLength": 2,
            "pattern": "[A-Z]{2,2}",
            "type": "string",
            "description": "The country this address is in, given as a two letter ISO 3166 country code.",
            "example": "NL"
          },
          "streetName": {
            "type": "string",
            "description": "Street name of this address.",
            "nullable": true,
            "example": "Da Costakade"
          },
          "postcode": {
            "type": "string",
            "description": "The postcode of this address.",
            "nullable": true,
            "example": "1053 XG"
          }
        },
        "additionalProperties": false,
        "description": "The postal address of this party."
      },
      "PreviousInstructingAgent": {
        "required": [
          "agent",
          "order"
        ],
        "type": "object",
        "properties": {
          "order": {
            "type": "integer",
            "description": "Order of the agent in the chain.",
            "format": "int32",
            "example": "1"
          },
          "agent": {
            "$ref": "#/components/schemas/Agent"
          },
          "previousInstructingAgentAccount": {
            "$ref": "#/components/schemas/PreviousInstructingAgentAccount"
          }
        },
        "additionalProperties": false,
        "description": "Agents who were previously involved with the payment."
      },
      "PreviousInstructingAgentAccount": {
        "required": [
          "iban"
        ],
        "type": "object",
        "properties": {
          "iban": {
            "maxLength": 34,
            "minLength": 5,
            "pattern": "[A-Z]{2,2}[0-9]{2,2}[a-zA-Z0-9]{1,30}",
            "type": "string",
            "description": "The International Bank Account Number (IBAN) for this account.",
            "example": "GB43PDIZURTAN33"
          }
        },
        "additionalProperties": false,
        "description": "The account information for a previous instructing agent."
      },
      "PrivateIdentification": {
        "type": "object",
        "properties": {
          "dateAndPlaceOfBirth": {
            "$ref": "#/components/schemas/DateAndPlaceOfBirth"
          },
          "other": {
            "minItems": 1,
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Other"
            },
            "description": "Other private identifications.",
            "nullable": true
          }
        },
        "additionalProperties": false,
        "description": "The party’s private or personal information."
      },
      "SchemeName": {
        "required": [
          "code",
          "proprietary"
        ],
        "type": "object",
        "properties": {
          "code": {
            "maxLength": 4,
            "minLength": 1,
            "pattern": "[A-Z]{4,4}",
            "type": "string",
            "description": "The identification scheme's four character identification code, as set out in the external code set for External Organisation Identification.",
