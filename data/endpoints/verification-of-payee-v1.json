{
  "openapi": "3.0.2",
  "info": {
    "title": "Verification of Payee",
    "version": "1.0"
  },
  "paths": {
    "/health": {
      "get": {
        "tags": [
          "ClearBank.VerificationOfPayee.Api"
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "/open-banking/vop/v1/payee-verifications": {
      "post": {
        "tags": [
          "PayeeVerificationEndpoint"
        ],
        "summary": "This endpoint is used to do a Verification of Payee check for EU payments",
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "description": "Your API Token, retrieved from the web portal.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "DigitalSignature",
            "in": "header",
            "description": "Signed hash of the body of the request. The hash is signed by your private key.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Request-Id",
            "in": "header",
            "description": "A unique identifier for the request.",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PayeeVerificationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PayeeVerificationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HttpValidationProblemDetails"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "FinancialInstitutionId": {
        "required": [
          "bicfi"
        ],
        "type": "object",
        "properties": {
          "bicfi": {
            "minLength": 1,
            "pattern": "[A-Z0-9]{4,4}[A-Z]{2,2}[A-Z0-9]{2,2}([A-Z0-9]{3,3}){0,1}",
            "type": "string",
            "description": "Business identifier code (BIC) - Code allocated to a financial institution by the ISO 9362 Registration Authority"
          }
        },
        "additionalProperties": false
      },
      "HttpValidationProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "nullable": true,
            "example": "",
            "description": "A URI reference [RFC3986] that identifies a problem type. When dereferenced,  it provides a human-readable documentation for the problem type. \nWhen not present, default value is assumed to be 'about:blank"
          },
          "title": {
            "type": "string",
            "nullable": true,
            "example": "",
            "description": "A short, human-readable summary of the problem type."
          },
          "status": {
            "type": "integer",
            "format": "int32",
            "nullable": true,
            "example": "",
            "description": "The HTTP status code ([RFC7231], Section 6) generated by the origin server for this occurrence of the problem."
          },
          "detail": {
            "type": "string",
            "nullable": true,
            "example": "",
            "description": "A human-readable explanation of what went wrong. It can include specifics about the issue, missing parameters, or invalid data."
          },
          "instance": {
            "type": "string",
            "nullable": true,
            "example": "",
            "description": "A URL reference to a retrieve more information about the error, if available."
          },
          "errors": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "nullable": true
          }
        },
        "additionalProperties": {}
      },
      "Identification": {
        "type": "object",
        "properties": {
          "organisationId": {
            "$ref": "#/components/schemas/OrganisationId"
          }
        },
        "additionalProperties": false
      },
      "OrganisationId": {
        "type": "object",
        "properties": {
          "lei": {
            "pattern": "[0-9]{4}[0]{2}[A-Z0-9]{12}[0-9]{2}",
            "type": "string",
            "description": "Legal Entity Identifier (LEI) - Unique alphanumeric code that has 20 characters and is based on the ISO 17442 standard.",
            "example": "9630006S8MTOVM7WP270",
            "nullable": true
          },
          "anyBIC": {
            "pattern": "[A-Z0-9]{4,4}[A-Z]{2,2}[A-Z0-9]{2,2}([A-Z0-9]{3,3}){0,1}",
            "type": "string",
            "description": "Business Identifier Code (BIC) - Code allocated to a financial institution by the ISO 9362 Registration Authority",
            "nullable": true
          },
          "others": {
            "$ref": "#/components/schemas/Others"
          }
        },
        "additionalProperties": false
      },
      "Others": {
        "type": "object",
        "properties": {
          "identificationNumber": {
            "maxLength": 256,
            "type": "string",
            "description": "Identification code of the the reference party, as defined by scheme in the SEPA Implementation Guide and the RT1 Interface Spec.",
            "nullable": true
          },
          "schemeNameCode": {
            "maxLength": 4,
            "type": "string",
            "description": "Item value. If ElementName is set to CD, then then values allowed are as per Scheme Name Code fields in the EPC and RT1 XSDs. If ElementName is set to Prtry, then any string is permitted.",
            "nullable": true
          },
          "schemeNameProprietary": {
            "maxLength": 35,
            "type": "string",
            "description": "Scheme name Item Element name. Set to either Cd (Code) or Prtry (Proprietary)",
            "example": "Cd",
            "nullable": true
          },
          "issuer": {
            "maxLength": 35,
            "type": "string",
            "description": "Issuer",
            "example": "Deutsche Bundesbank",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "Party": {
        "type": "object",
        "properties": {
          "name": {
            "maxLength": 140,
            "type": "string",
            "description": "The name of the intended payee.",
            "example": "Robert Miles",
            "nullable": true
          },
          "identification": {
            "$ref": "#/components/schemas/Identification"
          }
        },
        "additionalProperties": false
      },
      "PartyAccount": {
        "required": [
          "iban"
        ],
        "type": "object",
        "properties": {
          "iban": {
            "minLength": 1,
            "pattern": "[A-Z]{2,2}[0-9]{2,2}[a-zA-Z0-9]{1,30}",
            "example": "DE89370400440532013000",
            "type": "string",
            "description": "International Bank Account Number associated with the creditor account."
          }
        },
        "additionalProperties": false
      },
      "PartyAgent": {
        "type": "object",
        "properties": {
          "financialInstitutionId": {
            "$ref": "#/components/schemas/FinancialInstitutionId"
          }
        },
        "additionalProperties": false
      },
      "PayeeVerificationRequest": {
        "required": [
          "endToEndId"
        ],
        "type": "object",
        "properties": {
          "endToEndId": {
            "maxLength": 35,
            "minLength": 1,
            "type": "string",
            "description": "Unique identification, as assigned by the originating party, to unambiguously identify the transaction. This identification is passed on, unchanged, throughout the entire end-to-end chain."
          },
          "party": {
            "$ref": "#/components/schemas/Party"
          },
          "partyAccount": {
            "$ref": "#/components/schemas/PartyAccount"
          },
          "partyAgent": {
            "$ref": "#/components/schemas/PartyAgent"
          },
          "unstructuredRemittanceInformation": {
            "maxLength": 140,
            "type": "string",
            "description": "Additional information related to the payment to include unstructured details for the beneficiary, such as invoice numbers, references, or other contextual information.",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "PayeeVerificationResponse": {
        "type": "object",
        "properties": {
          "partyNameMatch": {
            "type": "string",
            "description": "Result of the Name Match. Possible codes include: MTCH, NMTC, CMTC, and NOAP.",
            "example": "MTCH",
            "nullable": true
          },
          "partyIdMatch": {
            "type": "string",
            "description": "Result of the Party Match. Possible codes include: MTCH, NMTC, CMTC, and NOAP.",
            "example": "NMTC",
            "nullable": true
          },
          "matchedName": {
            "type": "string",
            "description": "Matched name",
            "example": "Alex Turner",
            "nullable": true
          }
        },
        "additionalProperties": false
      }
    }
  }
}