                    "accountIban": {
                        "type": "string",
                        "nullable": true
                    },
                    "postalAddress": {
                        "$ref": "#/components/schemas/PostalAddress"
                    },
                    "identification": {
                        "$ref": "#/components/schemas/Identification"
                    }
                },
                "additionalProperties": false
            },
            "CreditorAgent": {
