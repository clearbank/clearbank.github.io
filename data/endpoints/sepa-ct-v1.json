{
    "openapi": "3.0.1",
    "info": {
        "title": "ClearBank.Sepa.Ct.Orchestrator.Api",
        "version": "1.0-SEPA-CT"
    },
    "paths": {
        "/v1/{institutionId}/payment": {
            "post": {
                "tags": [
                    "Sepa CT Payments"
                ],
                "summary": "Creates Outbound SEPA CT Payment",
                "description": "Creates Outbound SEPA CT Payment",
                "operationId": "Payment.Create",
                "parameters": [
                    {
                        "name": "institutionId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/CreateSepaOutboundPaymentRequest"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "202": {
                        "description": "Accepted",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/CreateSepaOutboundPaymentResponse"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HttpValidationProblemDetails"
                                }
                            }
                        }
                    },
                    "409": {
                        "description": "Conflict",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/v1/{institutionId}/payments/{sepaPaymentId}/recall-of-inbound": {
            "post": {
                "tags": [
                    "Sepa CT Payments"
                ],
                "summary": "Recall request result for a SEPA CT inbound payment",
                "description": "Approves or rejects the request for recall of a SEPA CT inbound payment",
                "operationId": "Payments.Inbound.RecallRequestResult",
                "parameters": [
                    {
                        "name": "sepaPaymentId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    },
                    {
                        "name": "institutionId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/RecallOfInboundPaymentReviewRequest"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "202": {
                        "description": "Accepted"
                    },
                    "400": {
                        "description": "Bad Request",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HttpValidationProblemDetails"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/v1/{institutionId}/payments/{paymentId}/recall": {
            "post": {
                "tags": [
                    "Sepa CT Payments"
                ],
                "summary": "Recalls Outbound SEPA CT Payment",
                "description": "Recalls Outbound SEPA CT Payment",
                "operationId": "Payment.Recall",
                "parameters": [
                    {
                        "name": "institutionId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    },
                    {
                        "name": "paymentId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/RecallOfOutboundPaymentRequest"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "202": {
                        "description": "Accepted"
                    },
                    "400": {
                        "description": "Bad Request",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/HttpValidationProblemDetails"
                                }
                            }
                        }
                    },
                    "409": {
                        "description": "Conflict"
                    }
                }
            }
        },
        "/v1/{institutionId}/payments/{sepaPaymentId}/return-of-inbound": {
            "post": {
                "tags": [
                    "Sepa CT Payments"
                ],
                "summary": "Customer initiated return for a SEPA CT inbound payment",
                "description": "Customer endpoint for initiating a return of a SEPA CT inbound payment",
                "operationId": "Payments.Inbound.ReturnOfInboundPayment",
                "parameters": [
                    {
                        "name": "institutionId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    },
                    {
                        "name": "sepaPaymentId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    }
                ],
                "responses": {
                    "202": {
                        "description": "Accepted"
                    },
                    "400": {
                        "description": "Bad Request",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "string"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "CreateSepaOutboundPaymentRequest": {
                "type": "object",
                "properties": {
                    "endToEndId": {
                        "type": "string",
                        "description": "Unique identification, as assigned by the originating party, to unambiguously identify the transaction. This identification is passed on, unchanged, throughout the entire end-to-end chain.",
                        "nullable": true,
                        "example": "End2EndId"
                    },
                    "amount": {
                        "type": "number",
                        "description": "Amount of money to be moved between the debtor and creditor, before deduction of charges.",
                        "format": "double",
                        "example": "2.99"
                    },
                    "currency": {
                        "type": "string",
                        "description": "An active or a historic currency where the unit of currency is explicit and compliant with ISO 4217.",
                        "nullable": true,
                        "example": "EUR"
                    },
                    "debtor": {
                        "$ref": "#/components/schemas/Debtor"
                    },
                    "creditor": {
                        "$ref": "#/components/schemas/Creditor"
                    },
                    "creditorAgent": {
                        "$ref": "#/components/schemas/CreditorAgent"
                    },
                    "remittanceInformationUnstructured": {
                        "type": "string",
                        "description": "Information supplied to enable the matching/reconciliation of an entry with the items that the payment is intended to settle, such as commercial invoices in an accounts receivable system, in an unstructured form",
                        "nullable": true,
                        "example": "My remittance information."
                    }
                },
                "additionalProperties": false
            },
            "CreateSepaOutboundPaymentResponse": {
                "type": "object",
                "properties": {
                    "paymentId": {
                        "type": "string",
                        "format": "uuid",
                        "readOnly": true,
                        "example": "1bfb7a86-7d9b-45ff-9d5c-34048efc4c8a"
                    }
                },
                "additionalProperties": false
            },
            "Creditor": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string",
                        "description": "The name used to identify the legal owner of the account from which to credit funds.",
                        "nullable": true,
                        "example": "John Doe"
                    },
                    "accountIban": {
                        "type": "string",
                        "description": "International Bank Account Number (IBAN) - identifier used internationally by financial institutions to uniquely identify the account of a customer.",
                        "nullable": true,
                        "example": "GB33BUKB20201555555555"
                    },
                    "postalAddress": {
                        "$ref": "#/components/schemas/PostalAddress"
                    },
                    "identification": {
                        "$ref": "#/components/schemas/Identification"
                    }
                },
                "additionalProperties": false
            },
            "CreditorAgent": {
                "type": "object",
                "properties": {
                    "bic": {
                        "type": "string",
                        "description": "Business identifier code (BIC) - Code allocated to a financial institution by the ISO 9362 Registration Authority",
                        "nullable": true,
                        "example": "BUKBGB20"
                    }
                },
                "additionalProperties": false
            },
            "DateAndPlaceOfBirth": {
                "type": "object",
                "properties": {
                    "dateOfBirth": {
                        "type": "string",
                        "description": "Date of birth of a person.",
                        "format": "date-time",
                        "nullable": true,
                        "example": "2004-05-15"
                    },
                    "placeOfBirth": {
                        "type": "string",
                        "description": "Place of birth of a person",
                        "nullable": true,
                        "example": "Birth Town"
                    }
                },
                "additionalProperties": false
            },
            "Debtor": {
                "type": "object",
                "properties": {
                    "name": {
                        "type": "string",
                        "description": "The name used to identify the legal owner of the account from which to debit funds.",
                        "nullable": true,
                        "example": "John Doe"
                    },
                    "accountIban": {
                        "type": "string",
                        "description": "International Bank Account Number associated with the debtor account to which a debit entry will be made as a result of the transaction.",
                        "nullable": true,
                        "example": "GB33BUKB20201555555555"
                    },
                    "postalAddress": {
                        "$ref": "#/components/schemas/PostalAddress"
                    },
                    "identification": {
                        "$ref": "#/components/schemas/Identification"
                    }
                },
                "additionalProperties": false
            },
            "HttpValidationProblemDetails": {
                "type": "object",
                "properties": {
                    "type": {
                        "type": "string",
                        "nullable": true
                    },
                    "title": {
                        "type": "string",
                        "nullable": true
                    },
                    "status": {
                        "type": "integer",
                        "format": "int32",
                        "nullable": true
                    },
                    "detail": {
                        "type": "string",
                        "nullable": true
                    },
                    "instance": {
                        "type": "string",
                        "nullable": true
                    },
                    "errors": {
                        "type": "object",
                        "additionalProperties": {
                            "type": "array",
                            "items": {
                                "type": "string"
                            }
                        },
                        "nullable": true,
                        "readOnly": true
                    }
                },
                "additionalProperties": {}
            },
            "Identification": {
                "type": "object",
                "properties": {
                    "organisationIdentification": {
                        "$ref": "#/components/schemas/OrganisationIdentification"
                    },
                    "privateIdentification": {
                        "$ref": "#/components/schemas/PrivateIdentification"
                    }
                },
                "additionalProperties": false
            },
            "OrganisationIdentification": {
                "type": "object",
                "properties": {
                    "bic": {
                        "type": "string",
                        "description": "Business identifier code (BIC) - Code allocated to a financial institution by the ISO 9362 Registration Authority",
                        "nullable": true,
                        "example": "BUKBGB20"
                    }
                },
                "additionalProperties": false
            },
            "PostalAddress": {
                "type": "object",
                "properties": {
                    "streetName": {
                        "type": "string",
                        "description": "Name of a street or thoroughfare.",
                        "nullable": true,
                        "example": "My Street"
                    },
                    "buildingNumber": {
                        "type": "string",
                        "description": "Number that identifies the position of a building on a street.",
                        "nullable": true,
                        "example": "1"
                    },
                    "townName": {
                        "type": "string",
                        "description": "Name of a built-up area, with defined boundaries, and a local government.",
                        "nullable": true,
                        "example": "London"
                    },
                    "postCode": {
                        "type": "string",
                        "description": "Identifier consisting of a group of letters and/or numbers that is added to a postal address to assist the sorting of mail.",
                        "nullable": true,
                        "example": "XX99 9XX"
                    },
                    "countrySubdivision": {
                        "type": "string",
                        "description": "Identifies a subdivision of a country such as state, region, county.",
                        "nullable": true,
                        "example": "London"
                    },
                    "country": {
                        "type": "string",
                        "description": "Nation with its own government.",
                        "nullable": true,
                        "example": "GB"
                    }
                },
                "additionalProperties": false
            },
            "PrivateIdentification": {
                "type": "object",
                "properties": {
                    "dateAndPlaceOfBirth": {
                        "$ref": "#/components/schemas/DateAndPlaceOfBirth"
                    },
                    "other": {
                        "type": "string",
                        "description": "Unique identification of a person, as assigned by an institution, using an identification scheme.",
                        "nullable": true,
                        "example": "Other identification."
                    }
                },
                "additionalProperties": false
            },
            "RecallOfInboundPaymentReviewRequest": {
                "type": "object",
                "properties": {
                    "recallResponseAccepted": {
                        "type": "boolean",
                        "description": "Accept or reject a request for recall of a SEPA CT inbound payment",
                        "example": "True"
                    },
                    "rejectCode": {
                        "type": "string",
                        "description": "Reason code required if recall request is rejected ",
                        "nullable": true,
                        "example": "CUST"
                    },
                    "additionalInfo": {
                        "type": "string",
                        "description": "Additional information",
                        "nullable": true,
                        "example": "Additional details."
                    }
                },
                "additionalProperties": false
            },
            "RecallOfOutboundPaymentRequest": {
                "type": "object",
                "properties": {
                    "recallCode": {
                        "type": "string",
                        "description": "Reason code to recall an Outbound SEPA CT Payment",
                        "nullable": true,
                        "example": "CUST"
                    },
                    "additionalInfo": {
                        "type": "string",
                        "description": "Additional Information",
                        "nullable": true,
                        "example": "Some additional information."
                    }
                },
                "additionalProperties": false
            }
        }
    }
}