{
    "openapi": "3.0.1",
    "info": {
        "title": "ClearBank.Sepa.Ct.Orchestrator.Api",
        "version": "1.0-SEPACT"
    },
    "paths": {
        "/v1/payments/sepa": {
            "post": {
                "tags": [
                    "Sepa CT Payments"
                ],
                "summary": "This endpoint will send a SEPA CT payment.",
                "operationId": "Payment.Create",
                "parameters": [
                    {
                        "name": "institutionId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/CreateSepaOutboundPaymentRequest"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "202": {
                        "description": "Accepted"
                    },
                    "400": {
                        "description": "Bad Request"
                    },
                    "409": {
                        "description": "Conflict"
                    }
                }
            }
        },
        "/v1/payments/sepa/{paymentId}/recall-response": {
            "post": {
                "tags": [
                    "This endpoint will approve or reject a request for a SEPA CT inbound payment."
                ],
                "operationId": "Payments.Inbound.RecallRequestResult",
                "parameters": [
                    {
                        "name": "paymentId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    },
                    {
                        "name": "institutionId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/RecallOfInboundPaymentReviewRequest"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "202": {
                        "description": "Accepted"
                    },
                    "400": {
                        "description": "Bad Request"
                    },
                    "404": {
                        "description": "Not Found"
                    },
                    "409": {
                        "description": "Conflict"
                    }
                }
            }
        },
        "/v1/payments/sepa/{paymentId}/recall": {
            "post": {
                "tags": [
                    "Sepa CT Payments"
                ],
                "summary": "Recalls Outbound SEPA CT Payment",
                "description": "Recalls Outbound SEPA CT Payment",
                "operationId": "Payment.Recall",
                "parameters": [
                    {
                        "name": "institutionId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    },
                    {
                        "name": "paymentId",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "format": "uuid"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/RecallOfOutboundPaymentRequest"
                            }
                        }
                    },
                    "required": true
                },
                "responses": {
                    "202": {
                        "description": "Accepted"
                    },
                    "400": {
                        "description": "Bad Request"
                    },
                    "409": {
                        "description": "Conflict"
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "CreateSepaOutboundPaymentRequest": {
                "required": [
                    "creditor",
                    "creditorAgent",
                    "debtor",
                    "endToEndId",
                    "remittanceInformationUnstructured"
                ],
                "type": "object",
                "properties": {
                    "endToEndId": {
                        "maxLength": 35,
                        "minLength": 1,
                        "type": "string"
                    },
                    "amount": {
                        "maximum": 10000000000000,
                        "minimum": 0,
                        "exclusiveMinimum": true,
                        "type": "number",
                        "format": "double"
                    },
                    "currency": {
                        "type": "string",
                        "nullable": true
                    },
                    "debtor": {
                        "$ref": "#/components/schemas/Debtor"
                    },
                    "creditor": {
                        "$ref": "#/components/schemas/Creditor"
                    },
                    "creditorAgent": {
                        "$ref": "#/components/schemas/CreditorAgent"
                    },
                    "remittanceInformationUnstructured": {
                        "maxLength": 140,
                        "minLength": 1,
                        "type": "string"
                    }
                },
                "additionalProperties": false
            },
            "Creditor": {
                "required": [
                    "accountIban",
                    "name",
                    "postalAddress"
                ],
                "type": "object",
                "properties": {
                    "name": {
                        "maxLength": 70,
                        "minLength": 1,
                        "type": "string"
                    },
                    "accountIban": {
                        "minLength": 1,
                        "type": "string"
                    },
                    "postalAddress": {
                        "$ref": "#/components/schemas/PostalAddress"
                    },
                    "identification": {
                        "$ref": "#/components/schemas/Identification"
                    }
                },
                "additionalProperties": false
            },
            "CreditorAgent": {
                "required": [
                    "bic"
                ],
                "type": "object",
                "properties": {
                    "bic": {
                        "minLength": 1,
                        "type": "string"
                    }
                },
                "additionalProperties": false
            },
            "DateAndPlaceOfBirth": {
                "type": "object",
                "properties": {
                    "dateOfBirth": {
                        "type": "string",
                        "format": "date-time",
                        "nullable": true
                    },
                    "placeOfBirth": {
                        "maxLength": 35,
                        "type": "string",
                        "nullable": true
                    }
                },
                "additionalProperties": false
            },
            "Debtor": {
                "required": [
                    "accountIban",
                    "name",
                    "postalAddress"
                ],
                "type": "object",
                "properties": {
                    "name": {
                        "maxLength": 70,
                        "minLength": 1,
                        "type": "string"
                    },
                    "accountIban": {
                        "minLength": 1,
                        "type": "string"
                    },
                    "postalAddress": {
                        "$ref": "#/components/schemas/PostalAddress"
                    },
                    "identification": {
                        "$ref": "#/components/schemas/Identification"
                    }
                },
                "additionalProperties": false
            },
            "Identification": {
                "type": "object",
                "properties": {
                    "organisationIdentification": {
                        "$ref": "#/components/schemas/OrganisationIdentification"
                    },
                    "privateIdentification": {
                        "$ref": "#/components/schemas/PrivateIdentification"
                    }
                },
                "additionalProperties": false
            },
            "OrganisationIdentification": {
                "type": "object",
                "properties": {
                    "bic": {
                        "type": "string",
                        "nullable": true
                    }
                },
                "additionalProperties": false
            },
            "PostalAddress": {
                "required": [
                    "country",
                    "streetName"
                ],
                "type": "object",
                "properties": {
                    "streetName": {
                        "maxLength": 70,
                        "minLength": 1,
                        "type": "string"
                    },
                    "buildingNumber": {
                        "type": "string",
                        "nullable": true
                    },
                    "townName": {
                        "type": "string",
                        "nullable": true
                    },
                    "postCode": {
                        "type": "string",
                        "nullable": true
                    },
                    "countrySubdivision": {
                        "type": "string",
                        "nullable": true
                    },
                    "country": {
                        "maxLength": 2,
                        "minLength": 1,
                        "type": "string",
                        "allOf": [
                            {
                                "pattern": "^[A-Z]{2}$"
                            },
                            {
                                "pattern": "^[A-Z]{2}$"
                            },
                            {
                                "pattern": "^[A-Z]{2}$"
                            },
                            {
                                "pattern": "^[A-Z]{2}$"
                            },
                            {
                                "pattern": "^[A-Z]{2}$"
                            }
                        ]
                    }
                },
                "additionalProperties": false
            },
            "PrivateIdentification": {
                "type": "object",
                "properties": {
                    "dateAndPlaceOfBirth": {
                        "$ref": "#/components/schemas/DateAndPlaceOfBirth"
                    },
                    "other": {
                        "type": "string",
                        "nullable": true
                    }
                },
                "additionalProperties": false
            },
            "RecallOfInboundPaymentReviewRequest": {
                "type": "object",
                "properties": {
                    "recallResponseAccepted": {
                        "type": "boolean"
                    },
                    "rejectCode": {
                        "type": "string",
                        "nullable": true
                    },
                    "additionalInfo": {
                        "type": "string",
                        "nullable": true
                    }
                },
                "additionalProperties": false
            },
            "RecallOfOutboundPaymentRequest": {
                "required": [
                    "recallCode"
                ],
                "type": "object",
                "properties": {
                    "recallCode": {
                        "maxLength": 4,
                        "minLength": 4,
                        "type": "string"
                    },
                    "additionalInfo": {
                        "type": "string",
                        "nullable": true
                    }
                },
                "additionalProperties": false
            }
        }
    }
}