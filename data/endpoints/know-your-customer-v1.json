{
  "openapi": "3.0.2",
  "info": {
    "title": "Customer Due Diligence API",
    "version": "1.0know-your-customer"
  },
  "paths": {
    "/customer-due-diligence/v1/retail/onboard": {
      "post": {
        "description": "Use this endpoint to conduct KYC checks for a new retail customer. If the checks pass, the provided details are then used to create a new retail customer.",
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "description": "Your API token, retrieved from the web portal.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "DigitalSignature",
            "in": "header",
            "description": "Signed hash of the body of the request. The hash is signed by your private key.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Request-Id",
            "in": "header",
            "description": "A unique identifier for the request.",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RetailCustomerCheckRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/RetailCustomerCheckRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/RetailCustomerCheckRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Accepted",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/RetailCustomerCheckResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RetailCustomerCheckResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/RetailCustomerCheckResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {              
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              }
            }
          }
        }
      }
    },
    "/customer-due-diligence/v1/legal-entity/onboard": {
      "post": {
        "tags": [
          "CustomerCheck"
        ],
        "parameters": [
          {
            "name": "Authorization",
            "in": "header",
            "description": "Your API token, retrieved from the web portal.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "DigitalSignature",
            "in": "header",
            "description": "Signed hash of the body of the request. The hash is signed by your private key.",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Request-Id",
            "in": "header",
            "description": "A unique identifier for the request.",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LegalEntityCheckRequest"
              }
            },
            "text/json": {
              "schema": {
                "$ref": "#/components/schemas/LegalEntityCheckRequest"
              }
            },
            "application/*+json": {
              "schema": {
                "$ref": "#/components/schemas/LegalEntityCheckRequest"
              }
            }
          }
        },
        "responses": {
          "202": {
            "description": "Accepted",
            "content": {
              "text/plain": {
                "schema": {
                  "$ref": "#/components/schemas/LegalEntityCheckResponse"
                }
              },
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LegalEntityCheckResponse"
                }
              },
              "text/json": {
                "schema": {
                  "$ref": "#/components/schemas/LegalEntityCheckResponse"
                }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProblemDetails"
                }
              },
              "application/problem+json": {
                "schema": {
                  "$ref": "#/components/schemas/ValidationProblemDetails"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Address": {
        "required": [
          "buildingNameNumber",
          "countryCode",
          "postalCode",
          "streetName"
        ],
        "type": "object",
        "properties": {
          "buildingNameNumber": {
            "maxLength": 40,
            "minLength": 1,
            "pattern": "^[a-zA-Z0-9\\-',.() ]+$",
            "type": "string",
            "example": "22(A)",
            "description": "The name or number of the customer's home at their address."
          },
          "streetName": {
            "maxLength": 50,
            "minLength": 1,
            "pattern": "^[a-zA-Z0-9\\-',.() ]+$",
            "type": "string",
            "example": "Long Road",
            "description": "The street of the customer's address."
          },
          "city": {
            "maxLength": 40,
            "pattern": "^[a-zA-Z0-9\\-',.() ]+$",
            "type": "string",
            "nullable": true,
            "example": "York",
            "description": "The postal city of the customer's address."
          },
          "county": {
            "maxLength": 40,
            "pattern": "^[a-zA-Z0-9\\-',.() ]+$",
            "type": "string",
            "nullable": true,
            "example": "Yorkshire",
            "description": "The county of the customer's address."
          },
          "postalCode": {
            "maxLength": 10,
            "minLength": 2,
            "pattern": "^([Gg][Ii][Rr] 0[Aa]{2})|((([A-Za-z][0-9]{1,2})|(([A-Za-z][A-Ha-hJ-Yj-y][0-9]{1,2})|(([A-Za-z][0-9][A-Za-z])|([A-Za-z][A-Ha-hJ-Yj-y][0-9]?[A-Za-z])))) [0-9][A-Za-z]{2})$",
            "type": "string",
            "example": "YO31 7UH",
            "description": "The postal code of the customer's address. This must be formatted as a UK postcode, including the appropriate use of whitespace."
          },
          "countryCode": {
            "$ref": "#/components/schemas/CountryCode",
            "description": "The country of the customer's address, represented as an ISO 3166 Alpha-3 country-code."
          }
        },
        "additionalProperties": false
      },
      "AccountOpeningAuthorityData": {
        "required": [
          "address",
          "dateOfBirth",
          "name",
          "nationality",
          "taxResidency"
        ],
        "type": "object",
        "properties": {
          "name": {
            "$ref": "#/components/schemas/LegalEntityPersonName"
          },
          "dateOfBirth": {
            "type": "string",
            "format": "date",
            "example": "1975-05-22",
            "description": "This person's date of birth, formatted yyyy-MM-dd."
          },
          "nationality": {
            "$ref": "#/components/schemas/CountryCode"
          },
          "address": {
            "$ref": "#/components/schemas/LegalEntityAddress"
          },
          "taxResidency": {
            "$ref": "#/components/schemas/CountryCode"
          }
        },
        "additionalProperties": false
      },
      "CountryCode": {
        "format": "ISO 3166 Alpha-3 country-code",
        "type": "string",
        "example": "GBR",
        "minLength": 3,
        "maxLength": 3,
        "description": "Given as an ISO 3166 Alpha-3 country-code."
      },
      "CustomerData": {
        "required": [
          "currentAddress",
          "dateOfBirth",
          "email",
          "name",
          "nationalInsuranceNumber",
          "nationality",
          "taxResidency"
        ],
        "type": "object",
        "properties": {
          "name": {
            "$ref": "#/components/schemas/PersonName",
            "description": "The customer's full name. Their first name and surname are required."
          },
          "dateOfBirth": {
            "type": "string",
            "format": "date",
            "example": "1976-01-26",
            "maxLength": 10,
            "description": "The customer's date of birth, formatted: yyyy-MM-dd."
          },
          "nationality": {
            "minItems": 1,
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CountryCode"
            },
            "description": "An array containing the customer's nationalities as ISO 3166 Alpha-3 country-codes. You can provide multiple values for customers with more than one nationality. Does not accept US nationals.",
            "example": ["GBR", "IRL"]
          },
          "taxResidency": {
            "minItems": 1,
            "maxItems": 1,
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/CountryCode"
            },
            "description": "An array containing the country the customer resides in for tax purposes, represented as an ISO 3166 Alpha-3 country-code. Currently does not accept more than one country.",
            "example": ["GBR"]
          },
          "nationalInsuranceNumber": {
            "minLength": 9,
            "maxLength": 9,
            "pattern": "^[a-zA-Z]{2}\\d{6}[a-zA-Z]$",
            "example": "AB112233C",
            "type": "string",
            "description": "The UK National Insurance (NI) number of the customer. Should not include whitespace."
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "example@emailprovider.co.uk",
            "description": "The customer's email address."
          },
          "mobile": {
            "pattern": "^(?:[+][1-9])?\\d{11,14}$",
            "type": "string",
            "nullable": true,
            "description": "The customer's international mobile number, including its country-code prefix. For example '+44' for UK numbers. The use of '+' is optional.",
            "example": "+447725666777"
          },
          "currentAddress": {
            "$ref": "#/components/schemas/Address",
            "description": "The customer's current residential address."
          },
          "idvEmailsEnabled": {
            "type": "boolean",
            "default": true,
            "description": "If set to false, you'll receive Additional Info Required webhooks."
          }
        },
        "additionalProperties": false
      },
      "PersonName": {
        "required": [
          "firstName",
          "surname"
        ],
        "type": "object",
        "properties": {
          "firstName": {
            "maxLength": 40,
            "minLength": 1,
            "pattern": "^[a-zA-Z.'\\- ]+$",
            "type": "string",
            "example": "Adrien"
          },
          "middleName": {
            "maxLength": 100,
            "pattern": "^[a-zA-Z.'\\- ]+$",
            "type": "string",
            "nullable": true,
            "example": "Edin"
          },
          "surname": {
            "maxLength": 40,
            "minLength": 1,
            "pattern": "^[a-zA-Z.'\\- ]+$",
            "type": "string",
            "example": "Reed-Myers"
          }
        },
        "additionalProperties": false
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "nullable": true,
            "description": "A URI reference [RFC3986] that identifies a problem type. When dereferenced,  it provides a human-readable documentation for the problem type. When not present, default value is assumed to be 'about:blank'."
          },
          "title": {
            "type": "string",
            "nullable": true,
            "description": "A short, human-readable summary of the problem type."
          },
          "status": {
            "type": "integer",
            "format": "int32",
            "nullable": true,
            "description": "The HTTP status code ([RFC7231], Section 6) generated by the origin server for this occurrence of the problem."
          },
          "detail": {
            "type": "string",
            "nullable": true,
            "description": "A human-readable explanation of what went wrong. It can include specifics about the issue, missing parameters, or invalid data."
          },
          "instance": {
            "type": "string",
            "nullable": true,
            "description": "A URL reference to a retrieve more information about the error, if available."
          }
        },
        "additionalProperties": {}
      },
      "RetailCustomerCheckRequest": {
        "required": [
          "customerData"
        ],
        "type": "object",
        "properties": {
          "customerData": {
            "$ref": "#/components/schemas/CustomerData"
          }
        },
        "additionalProperties": false
      },
      "RetailCustomerCheckResponse": {
        "type": "object",
        "properties": {
          "applicationId": {
            "type": "string",
            "format": "uuid",
            "example": "aac7c700-1ea6-5664-8804-ceeb066d3cf5",
            "description": "A unique ID for each submitted application. Use this to identify which application a corresponding webhook pertains to."
          }
        },
        "additionalProperties": false
      },
      "ValidationProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "nullable": true
          },
          "title": {
            "type": "string",
            "nullable": true
          },
          "status": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "detail": {
            "type": "string",
            "nullable": true
          },
          "instance": {
            "type": "string",
            "nullable": true
          },
          "errors": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "nullable": true
          }
        },
        "additionalProperties": { }
      },
      "DirectorData": {
        "required": [
          "address",
          "dateOfBirth",
          "name",
          "nationality"
        ],
        "type": "object",
        "properties": {
          "name": {
            "$ref": "#/components/schemas/LegalEntityPersonName"
          },
          "dateOfBirth": {
            "type": "string",
            "format": "date",
            "description": "This person's date of birth, formatted yyyy-MM-dd.",
            "example": "1995-05-26"
          },
          "nationality": {
            "$ref": "#/components/schemas/CountryCode"
          },
          "address": {
            "$ref": "#/components/schemas/LegalEntityAddress"
          }
        },
        "additionalProperties": false
      },
      "LegalEntityAddress": {
        "required": [
          "buildingNameNumber",
          "city",
          "countryCode",
          "postalCode",
          "streetName"
        ],
        "type": "object",
        "properties": {
          "buildingNameNumber": {
            "maxLength": 255,
            "minLength": 1,
            "pattern": "^[a-zA-Z0-9\\-',.() ]+$",
            "type": "string",
            "example": "255",
            "description": "The name or number of the building at this address."
          },
          "streetName": {
            "maxLength": 255,
            "minLength": 1,
            "pattern": "^[a-zA-Z0-9\\-',.() ]+$",
            "type": "string",
            "example": "Long Road",
            "description": "The name of the street this address is on."
          },
          "city": {
            "maxLength": 255,
            "minLength": 1,
            "pattern": "^[a-zA-Z\\-'. ]+$",
            "type": "string",
            "example": "Manchester",
            "description": "The city of this address."
          },
          "county": {
            "maxLength": 255,
            "pattern": "^[a-zA-Z'. ]+$",
            "type": "string",
            "nullable": true,
            "example": "Greater Manchester",
            "description": "The county of this address."
          },
          "postalCode": {
            "maxLength": 8,
            "minLength": 2,
            "type": "string",
            "example": "M1 1AF",
            "description": "The postcode of this address."
          },
          "countryCode": {
            "$ref": "#/components/schemas/CountryCode"
          }
        },
        "additionalProperties": false
      },
      "LegalEntityAddressInfo": {
        "required": [
          "registeredAddress"
        ],
        "type": "object",
        "properties": {
          "registeredAddress": {
            "$ref": "#/components/schemas/LegalEntityAddress"
          },
          "tradingAddress": {
            "$ref": "#/components/schemas/OptionalBusinessAddress"
          }
        },
        "additionalProperties": false
      },
      "OptionalBusinessAddress": {
        "type": "object",
        "properties": {
          "buildingNameNumber": {
            "maxLength": 255,
            "pattern": "^[a-zA-Z0-9\\-',.() ]+$",
            "type": "string",
            "nullable": true,
            "example": "255",
            "description": "The name or number of the building at this address."
          },
          "streetName": {
            "maxLength": 255,
            "pattern": "^[a-zA-Z0-9\\-',.() ]+$",
            "type": "string",
            "nullable": true,
            "example": "Long Road",
            "description": "The name of the street this address is on."
          },
          "city": {
            "maxLength": 255,
            "pattern": "^[a-zA-Z\\-'. ]+$",
            "type": "string",
            "nullable": true,
            "example": "Manchester",
            "description": "The city of this address."
          },
          "county": {
            "maxLength": 255,
            "pattern": "^[a-zA-Z'. ]+$",
            "type": "string",
            "nullable": true,
            "example": "Greater Manchester",
            "description": "The county of this address."
          },
          "postalCode": {
            "maxLength": 8,
            "minLength": 2,
            "type": "string",
            "nullable": true,
            "example": "M1 1AF",
            "description": "The postcode of this address."
          },
          "countryCode": {
            "$ref": "#/components/schemas/CountryCode"
          }
        },
        "additionalProperties": false
      },
      "LegalEntityCheckRequest": {
        "required": [
          "businessData",
          "controllerData",
          "directorData",
          "uboData"
        ],
        "type": "object",
        "properties": {
          "businessData": {
            "$ref": "#/components/schemas/LegalEntityData"
          },
          "uboData": {
            "maxItems": 10,
            "minItems": 1,
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UboData"
            },
            "description": "The Ultimate Owning Beneficiaries (UBOs) of a company are the natural or non-natural persons with ownership in the company. They may hold ownership either directly or indirectly through a parent entity."
          },
          "controllerData": {
            "minItems": 1,
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ControllerData"
            },
            "description": "A person who exercises control over a business. Either by the appointment, or influence over the appointment of, the majority of the business' board of directors (or equivalent management body). Or, a person with responsibility for the day to day operation of the business."
          },
          "directorData": {
            "minItems": 1,
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/DirectorData"
            },
            "description": "The registered directors of this business."
          },
          "accountOpeningAuthorityData": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AccountOpeningAuthorityData"
            },
            "description": "An individual authorised to create, close, or modify this business' account.",
            "nullable": true
          },
          "signatoryData": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SignatoryData"
            },
            "description": "A signatory is an individual authorised to instruct the movement of funds, assets, or approve account openings.",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "LegalEntityCheckResponse": {
        "type": "object",
        "properties": {
          "applicationId": {
            "type": "string",
            "format": "uuid",
            "description": "The unique identifier for this business' KYB check.",
            "example": "47ca0728-7db3-577f-94f2-80668239f430"
          }
        },
        "additionalProperties": false
      },
      "ControllerData": {
        "required": [
          "address",
          "dateOfBirth",
          "email",
          "name",
          "nationalInsuranceNumber",
          "nationality",
          "tax",
          "taxResidency"
        ],
        "type": "object",
        "properties": {
          "name": {
            "$ref": "#/components/schemas/LegalEntityPersonName"
          },
          "dateOfBirth": {
            "type": "string",
            "format": "date",
            "description": "This person's date of birth, formatted yyyy-MM-dd.",
            "example": "1974-04-22"
          },
          "nationality": {
            "$ref": "#/components/schemas/CountryCode"
          },
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email",
            "description": "This person's email address.",
            "example": "my.email@example.com"
          },
          "mobile": {
            "pattern": "^\\+?\\d+$",
            "type": "string",
            "nullable": true,
            "description": "This person's mobile number.",
            "example": "01234567891"
          },
          "address": {
            "$ref": "#/components/schemas/LegalEntityAddress"
          },
          "taxResidency": {
            "$ref": "#/components/schemas/CountryCode"
          },
          "tax": {
            "$ref": "#/components/schemas/ControllerTaxInfo"
          },
          "nationalInsuranceNumber": {
            "maxLength": 10,
            "minLength": 1,
            "pattern": "^[a-zA-Z0-9]+$",
            "type": "string",
            "description": "This person's National Insurance (NI) number.",
            "example": "PD224466D"
          }
        },
        "additionalProperties": false
      },
      "ControllerTaxInfo": {
        "required": [
          "validSelfCertification"
        ],
        "type": "object",
        "properties": {
          "validSelfCertification": {
            "type": "boolean",
            "description": "Whether this tax controller's self certification is valid.",
            "example": true
          }
        },
        "additionalProperties": false
      },
      "LegalEntityData": {
        "required": [
          "address",
          "annualRevenue",
          "businessName",
          "businessType",
          "companyRegistrationNumber",
          "countryOfOperations",
          "incorporationDate",
          "sicCode",
          "sourceOfFunds",
          "tax"
        ],
        "type": "object",
        "description": "The details of this business, including their address, tax information, and registration details.",
        "properties": {
          "businessType": {
            "$ref": "#/components/schemas/LegalEntityType"
          },
          "businessName": {
            "$ref": "#/components/schemas/LegalEntityName"
          },
          "address": {
            "$ref": "#/components/schemas/LegalEntityAddressInfo"
          },
          "sicCode": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "The Standard Industrial Classification (SIC) codes applicable to this business.",
            "example": ["07100"]
          },
          "incorporationDate": {
            "type": "string",
            "format": "date",
            "description": "The date this business was incorporated, formatted yyyy-MM-dd.",
            "example": "2005-05-22"
          },
          "companyRegistrationNumber": {
            "maxLength": 10,
            "minLength": 1,
            "pattern": "^[a-zA-Z0-9]+$",
            "type": "string",
            "example": "55TORXBS",
            "description": "This company's registration number."
          },
          "annualRevenue": {
            "maximum": 99999999999.99,
            "minimum": 0.01,
            "type": "number",
            "format": "double",
            "example": 1000000.12,
            "description": "The annual revenue of the business. If this business has not yet operated for an entire year, an estimate will suffice."
          },
          "sourceOfFunds": {
            "minLength": 1,
            "type": "string",
            "description": "A freetext description of the source of this business' funds.",
            "example": "Director's loan"
          },
          "countryOfOperations": {
            "$ref": "#/components/schemas/CountryCode"
          },
          "tax": {
            "$ref": "#/components/schemas/LegalEntityTaxInfo"
          }
        },
        "additionalProperties": false
      },
      "SignatoryData": {
        "required": [
          "address",
          "dateOfBirth",
          "name",
          "nationality",
          "taxResidency"
        ],
        "type": "object",
        "properties": {
          "name": {
            "$ref": "#/components/schemas/LegalEntityPersonName"
          },
          "dateOfBirth": {
            "type": "string",
            "format": "date",
            "description": "This person's date of birth, formatted yyyy-MM-dd.",
            "example": "1988-05-25"
          },
          "nationality": {
            "$ref": "#/components/schemas/CountryCode"
          },
          "address": {
            "$ref": "#/components/schemas/LegalEntityAddress"
          },
          "taxResidency": {
            "$ref": "#/components/schemas/CountryCode"
          }
        },
        "additionalProperties": false
      },
      "LegalEntityName": {
        "required": [
          "registeredName"
        ],
        "type": "object",
        "properties": {
          "registeredName": {
            "maxLength": 255,
            "minLength": 1,
            "pattern": "^[a-zA-Z\\-'. ]+$",
            "type": "string",
            "example": "Your Company Ltd",
            "description": "This business' registered name."
          },
          "tradingName": {
            "maxLength": 255,
            "pattern": "^[a-zA-Z\\-'. ]+$",
            "type": "string",
            "nullable": true,
            "example": "Your Company",
            "description": "This business' trading name."
          }
        },
        "additionalProperties": false
      },
      "LegalEntityPersonName": {
        "required": [
          "firstName",
          "surname"
        ],
        "type": "object",
        "properties": {
          "firstName": {
            "maxLength": 255,
            "minLength": 1,
            "pattern": "^[a-zA-Z.'\\- ]+$",
            "type": "string",
            "example": "Miles",
            "description": "This person's first name."
          },
          "middleName": {
            "maxLength": 255,
            "pattern": "^[a-zA-Z.'\\- ]+$",
            "type": "string",
            "nullable": true,
            "example": "Middle",
            "description": "This person's middle name."
          },
          "surname": {
            "maxLength": 255,
            "minLength": 1,
            "pattern": "^[a-zA-Z.'\\- ]+$",
            "type": "string",
            "example": "Gilligan",
            "description": "This person's last name."
          }
        },
        "additionalProperties": false
      },
      "LegalEntityTaxInfo": {
        "required": [
          "nameOfSelfCertificationSignee",
          "positionOfSelfCertificationSignee",
          "taxResidency",
          "validSelfCertification",
          "vatRegistrationNumber"
        ],
        "type": "object",
        "properties": {
          "validSelfCertification": {
            "type": "boolean"
          },
          "nameOfSelfCertificationSignee": {
            "maxLength": 255,
            "minLength": 1,
            "pattern": "^[a-zA-Z\\-'. ]+$",
            "type": "string",
            "example": "John Smith",
            "description": "The full name of the self certification signee."
          },
          "positionOfSelfCertificationSignee": {
            "maxLength": 255,
            "minLength": 1,
            "pattern": "^[a-zA-Z\\-'. ]+$",
            "type": "string",
            "example": "Financial Executive",
            "description": "The title of the self certification signee."
          },
          "vatRegistrationNumber": {
            "maxLength": 15,
            "minLength": 1,
            "pattern": "^[a-zA-Z0-9 ]+$",
            "type": "string",
            "example": "GB123456789",
            "description": "This business' VAT registration number."
          },
          "taxResidency": {
            "$ref": "#/components/schemas/CountryCode"
          }
        },
        "additionalProperties": false
      },
      "LegalEntityType": {
        "enum": [
          "Ltd"
        ],
        "type": "string",
        "description": "This will always be `Ltd`.",
        "example": "Ltd"
      },
      "UboData": {
        "required": [
          "address",
          "dateOfBirth",
          "email",
          "name",
          "nationality",
          "ownershipPercentage",
          "taxResidency",
          "type"
        ],
        "type": "object",
        "properties": {
          "type": {
            "$ref": "#/components/schemas/UboType"
          },
          "ownershipPercentage": {
            "maximum": 100,
            "minimum": 0.01,
            "type": "number",
            "format": "double",
            "example": 100,
            "description": "The ownership percentage this UBO has of the company. Expressed as a percentage to two decimal places."
          },
          "name": {
            "$ref": "#/components/schemas/LegalEntityPersonName"
          },
          "dateOfBirth": {
            "type": "string",
            "format": "date",
            "description": "This person's date of birth, formatted yyyy-MM-dd.",
            "example": "1966-05-29"
          },
          "nationality": {
            "$ref": "#/components/schemas/CountryCode"
          },
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email",
            "example": "my.examplemail@domain.com",
            "description": "This person's email address."
          },
          "mobile": {
            "pattern": "^\\+?\\d+$",
            "type": "string",
            "nullable": true,
            "example": "+441234567890",
            "description": "This person's mobile number. May include the country code."
          },
          "address": {
            "$ref": "#/components/schemas/LegalEntityAddress"
          },
          "taxResidency": {
            "$ref": "#/components/schemas/CountryCode"
          }
        },
        "additionalProperties": false
      },
      "UboType": {
        "enum": [
          "Natural",
          "NonNatural"
        ],
        "type": "string",
        "example": "Natural",
        "description": "Used to specify whether the UBO is a natural person or a non-natural entity."
      }
    }
  }
}